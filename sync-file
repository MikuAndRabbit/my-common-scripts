#!/usr/bin/env bash

# ==============================================================================
# 脚本名称: sync-file
# 描述: 比较两个文件的内容（基于哈希），不同则交互式同步。
#       支持 BLAKE3 (优先) 和 SHA-256 哈希算法，兼容 macOS 和 Linux。
# 用法: 
#   ./sync-file <文件1> <文件2>
# ==============================================================================

# 严格模式
set -uo pipefail

# 定义颜色
readonly COLOR_RESET="\033[0m"
readonly COLOR_GREEN="\033[1;32m"
readonly COLOR_BLUE="\033[1;34m"
readonly COLOR_YELLOW="\033[1;33m"
readonly COLOR_RED="\033[1;31m"
readonly COLOR_BOLD="\033[1m"
readonly COLOR_DIM="\033[2m"

# 错误处理函数
error_exit() {
    echo -e "${COLOR_RED}错误: $1${COLOR_RESET}" >&2
    exit 1
}

# 检查参数
if [[ $# -ne 2 ]]; then
    echo -e "${COLOR_BLUE}用法:${COLOR_RESET} $0 <文件1> <文件2>"
    exit 1
fi

FILE1="$1"
FILE2="$2"

# 检查文件是否存在
[[ -f "$FILE1" ]] || error_exit "文件 '$FILE1' 不存在或不是普通文件。"
[[ -f "$FILE2" ]] || error_exit "文件 '$FILE2' 不存在或不是普通文件。"

# --- 跨平台兼容函数 ---

# 获取哈希值 (优先 BLAKE3, 其次 SHA-256)
get_hash() {
    local target="$1"
    if command -v b3sum >/dev/null 2>&1; then
        b3sum "$target" | awk '{print $1}'
    elif command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$target" | awk '{print $1}'
    elif command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$target" | awk '{print $1}'
    else
        error_exit "未在系统中找到 b3sum, sha256sum 或 shasum 命令。"
    fi
}

# 获取文件最后修改时间戳 (秒)
get_mtime() {
    local target="$1"
    if [[ "$OSTYPE" == "darwin"* ]]; then
        stat -f %m "$target"
    else
        stat -c %Y "$target"
    fi
}

# 格式化时间戳
format_time() {
    local ts="$1"
    if [[ "$OSTYPE" == "darwin"* ]]; then
        date -r "$ts" "+%Y-%m-%d %H:%M:%S"
    else
        date -d "@$ts" "+%Y-%m-%d %H:%M:%S"
    fi
}

# --- 核心逻辑 ---

echo -e "${COLOR_BLUE}正在计算哈希并比较内容...${COLOR_RESET}"

HASH1=$(get_hash "$FILE1")
HASH2=$(get_hash "$FILE2")

if [[ "$HASH1" == "$HASH2" ]]; then
    echo -e "${COLOR_GREEN}✓ 文件内容完全一致，无需同步。${COLOR_RESET}"
    exit 0
fi

echo -e "${COLOR_YELLOW}! 文件内容不同。${COLOR_RESET}"

MTIME1=$(get_mtime "$FILE1")
MTIME2=$(get_mtime "$FILE2")

TIME_STR1=$(format_time "$MTIME1")
TIME_STR2=$(format_time "$MTIME2")

# 判断新旧
LABEL1=""
LABEL2=""
if [[ "$MTIME1" -gt "$MTIME2" ]]; then
    LABEL1=" ${COLOR_GREEN}(最新)${COLOR_RESET}"
elif [[ "$MTIME2" -gt "$MTIME1" ]]; then
    LABEL2=" ${COLOR_GREEN}(最新)${COLOR_RESET}"
fi

echo -e "\n${COLOR_BOLD}文件信息对比:${COLOR_RESET}"
echo -e "1. ${FILE1} : ${TIME_STR1}${LABEL1}"
echo -e "2. ${FILE2} : ${TIME_STR2}${LABEL2}"
echo -e "${COLOR_DIM}----------------------------------------${COLOR_RESET}"

# 交互式菜单
echo -e "请选择同步策略:"
echo -e "  ${COLOR_BLUE}1)${COLOR_RESET} 用 文件1 覆盖 文件2  (1 -> 2)"
echo -e "  ${COLOR_BLUE}2)${COLOR_RESET} 用 文件2 覆盖 文件1  (2 -> 1)"
echo -e "  ${COLOR_BLUE}3)${COLOR_RESET} 自动同步 (保留最新修改的文件)"
echo -e "  ${COLOR_BLUE}0)${COLOR_RESET} 跳过 (不进行任何更新)"
echo

read -p "请输入选项 [0-3]: " CHOICE

case "$CHOICE" in
    1)
        echo -e "${COLOR_BLUE}正在将 $FILE1 同步到 $FILE2...${COLOR_RESET}"
        cp -f "$FILE1" "$FILE2"
        ;;
    2)
        echo -e "${COLOR_BLUE}正在将 $FILE2 同步到 $FILE1...${COLOR_RESET}"
        cp -f "$FILE2" "$FILE1"
        ;;
    3)
        if [[ "$MTIME1" -gt "$MTIME2" ]]; then
            echo -e "${COLOR_BLUE}文件1 较新，正在同步到 文件2...${COLOR_RESET}"
            cp -f "$FILE1" "$FILE2"
        elif [[ "$MTIME2" -gt "$MTIME1" ]]; then
            echo -e "${COLOR_BLUE}文件2 较新，正在同步到 文件1...${COLOR_RESET}"
            cp -f "$FILE2" "$FILE1"
        else
            echo -e "${COLOR_YELLOW}两个文件时间戳相同，无需自动同步。${COLOR_RESET}"
        fi
        ;;
    *)
        echo -e "${COLOR_DIM}已取消同步操作。${COLOR_RESET}"
        exit 0
        ;;
esac

echo -e "${COLOR_GREEN}✓ 同步完成！${COLOR_RESET}"
